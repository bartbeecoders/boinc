# Copy to config.env on the VPS (never commit config.env — it may hold tokens).
#   cp config.env.example config.env && chmod 600 config.env

# GitHub repository that owns the runner (org/repo).
# For an org-level runner use OWNER only and set RUNNER_SCOPE=org.
GITHUB_OWNER=bartbeecoders
GITHUB_REPO=boinc
RUNNER_SCOPE=repo          # repo | org

# Display name shown in GitHub → Settings → Actions → Runners.
RUNNER_NAME=vps-boinc-1

# Extra labels (comma-separated). GitHub always adds self-hosted, Linux, X64.
# Example: use runs-on: [self-hosted, linux, x64, vps] in a workflow.
RUNNER_LABELS=vps,boinc

# Install directory on the VPS (owned by the service user).
RUNNER_HOME=/home/bart/actions-runner

# Linux user that runs the agent (must exist; should have passwordless sudo
# only if your workflows need it — prefer no sudo for untrusted jobs).
RUNNER_USER=bart

# Work directory for job checkouts (defaults to $RUNNER_HOME/_work).
# RUNNER_WORKDIR=/home/bart/actions-runner/_work

# ---- Registration (one of the following) ---------------------------------
#
# A) One-shot registration token from the GitHub UI (expires ~1 hour):
#    Repo → Settings → Actions → Runners → New self-hosted runner
#    Copy the token after "./config.sh --url ... --token"
# REGISTRATION_TOKEN=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
#
# B) A PAT (or fine-grained token) used only to *create* a registration
#    token via the API. Needs "Administration" write on the repo (classic:
#    repo scope for private repos, public_repo is not enough for runners —
#    use a classic PAT with `repo` for private, or fine-grained with
#    Administration: Read and write). Never leave a long-lived PAT in this
#    file after install; install-host.sh unsets it once config finishes.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
